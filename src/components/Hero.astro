---
---

<section class="hero">
  <div class="hero-content">
    <h1>El Bondi Colectivo</h1>
    <p class="subtitle">Catálogo de obras - Duty Free</p>
    <p class="description">Descubre una selección exclusiva de obras de arte contemporáneo</p>
  </div>
  <div class="hero-stats">
    <div class="stat">
      <span class="stat-number">15</span>
      <span class="stat-label">Obras</span>
    </div>
    <div class="stat">
      <span class="stat-number">3</span>
      <span class="stat-label">Artistas</span>
    </div>
    <div class="stat">
      <span class="stat-number">5</span>
      <span class="stat-label">Categorías</span>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--spacing-xl) var(--spacing-lg);
    border-bottom: 1px solid var(--border-color);
    max-width: 1600px;
    margin: 0 auto;
  }

  .hero-content {
    margin-bottom: var(--spacing-xl);
  }

  h1 {
    font-size: 4rem;
    margin-bottom: var(--spacing-md);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 1.5rem;
    color: var(--text-light);
    margin-bottom: var(--spacing-md);
    font-weight: 500;
  }

  .description {
    font-size: 1rem;
    color: var(--text-light);
    max-width: 600px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--border-color);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.1rem;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>