<nav class="nav">
  <div class="nav-container">
    <div class="nav-left">
      <h1 class="logo">El Bondi</h1>
      <h2 class="logo-subtitle">Colectivo</h2>
    </div>
    <ul class="nav-links">
      <li><a href="#catalogo">Catálogo</a></li>
      <li><a href="#acerca">Acerca de</a></li>
      <li><a href="#escritos">Escritos</a></li>
      <li><a href="#contacto">Contacto</a></li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    border-bottom: 1px solid var(--border-color);
    padding: var(--spacing-xl) var(--spacing-lg);
    position: sticky;
    top: 0;
    background: var(--secondary);
    z-index: 100;
  }

  .nav-container {
    max-width: 1600px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-xl);
  }

  .nav-left {
    display: flex;
    gap: var(--spacing-md);
    align-items: baseline;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .logo-subtitle {
    font-size: 1rem;
    font-weight: 400;
    color: var(--text-light);
  }

  .nav-links {
    display: flex;
    gap: var(--spacing-xl);
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-light);
    transition: color 0.3s;
    position: relative;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  @media (max-width: 768px) {
    .nav {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .nav-container {
      flex-direction: column;
      gap: var(--spacing-lg);
    }

    .nav-links {
      gap: var(--spacing-lg);
      font-size: 0.85rem;
    }

    .logo {
      font-size: 1rem;
    }
  }
</style>