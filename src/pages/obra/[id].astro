---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import artworksData from '../../data/artworks.json';

interface Artwork {
  id: number;
  title: string;
  artist: string;
  category: string;
  price: string;
  image: string;
  description: string;
  longDescription: string;
  dimensions: string;
  year: number;
  medium: string;
  availability: string;
  tags: string[];
}

export async function getStaticPaths() {
  return artworksData.artworks.map((artwork: Artwork) => ({
    params: { id: String(artwork.id) },
    props: { artwork },
  }));
}

const { artwork } = Astro.props as { artwork: Artwork };
const allArtworks = artworksData.artworks;
const currentIndex = allArtworks.findIndex((a: Artwork) => a.id === artwork.id);
const nextArtwork = allArtworks[(currentIndex + 1) % allArtworks.length];
const prevArtwork = allArtworks[(currentIndex - 1 + allArtworks.length) % allArtworks.length];
---

<Layout title={artwork.title}>
  <Navigation />
  
  <section class="work-detail">
    <div class="work-container">
      <div class="work-header">
        <a href="/#catalogo" class="back-link">← Volver al catálogo</a>
        <h1>{artwork.title}</h1>
      </div>

      <div class="work-content">
        <div class="work-image">
          <img src={artwork.image} alt={artwork.title} />
        </div>

        <div class="work-info">
          <div class="work-meta">
            <h2>{artwork.title}</h2>
            <p class="artist">{artwork.artist}</p>
            
            <div class="details">
              <div class="detail-item">
                <span class="label">Categoría</span>
                <span class="value">{artwork.category}</span>
              </div>
              <div class="detail-item">
                <span class="label">Año</span>
                <span class="value">{artwork.year}</span>
              </div>
              <div class="detail-item">
                <span class="label">Dimensiones</span>
                <span class="value">{artwork.dimensions}</span>
              </div>
              <div class="detail-item">
                <span class="label">Técnica</span>
                <span class="value">{artwork.medium}</span>
              </div>
              <div class="detail-item">
                <span class="label">Estado</span>
                <span class="value availability">{artwork.availability}</span>
              </div>
            </div>

            <div class="price-section">
              <p class="price">{artwork.price}</p>
              <button class="contact-btn">Contactar para comprar</button>
            </div>

            <div class="tags">
              {artwork.tags.map((tag: string) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>

            <div class="share-buttons">
              <button class="share-btn" onclick="share('whatsapp')">
                WhatsApp
              </button>
              <button class="share-btn" onclick="share('twitter')">
                Twitter
              </button>
              <button class="share-btn" onclick="share('facebook')">
                Facebook
              </button>
              <button class="share-btn" onclick="share('email')">
                Email
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="description-section">
        <h3>Sobre la obra</h3>
        <p>{artwork.longDescription}</p>
      </div>

      <!-- NAVEGACIÓN ENTRE OBRAS -->
      <div class="navigation-section">
        <a href={`/obra/${prevArtwork.id}`} class="nav-artwork prev">
          <span>← Anterior</span>
          <p>{prevArtwork.title}</p>
        </a>
        <a href={`/obra/${nextArtwork.id}`} class="nav-artwork next">
          <span>Siguiente →</span>
          <p>{nextArtwork.title}</p>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  function share(platform: string) {
    const title = document.querySelector('h1')?.textContent || '';
    const url = window.location.href;
    
    if (platform === 'whatsapp') {
      window.open(`https://wa.me/?text=${encodeURIComponent(`Mira esta obra: ${title} - ${url}`)}`);
    } else if (platform === 'twitter') {
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${url}`);
    } else if (platform === 'facebook') {
      window.open(`https://www.facebook.com/sharer/sharer.php?u=${url}`);
    } else if (platform === 'email') {
      window.location.href = `mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(url)}`;
    }
  }
</script>

<style>
  .work-detail {
    padding: var(--spacing-xl) var(--spacing-lg);
    min-height: 100vh;
    border-bottom: 1px solid var(--border-color);
  }

  .work-container {
    max-width: 1600px;
    margin: 0 auto;
  }

  .work-header {
    margin-bottom: var(--spacing-xl);
  }

  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--text-light);
    text-decoration: none;
    margin-bottom: var(--spacing-md);
    transition: color 0.3s;
  }

  .back-link:hover {
    color: var(--text);
  }

  .work-header h1 {
    font-size: 2.5rem;
    margin: 0;
  }

  .work-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
  }

  .work-image {
    position: relative;
    aspect-ratio: 1;
    background: #f5f5f5;
    border-radius: 8px;
    overflow: hidden;
  }

  .work-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .work-meta h2 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .artist {
    font-size: 1rem;
    color: var(--text-light);
    margin-bottom: var(--spacing-lg);
  }

  .details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color);
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-light);
    font-weight: 600;
  }

  .value {
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 500;
  }

  .availability.value {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-sm);
    background: #f0f0f0;
    border-radius: 4px;
  }

  .price-section {
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color);
  }

  .price {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--spacing-md);
  }

  .contact-btn {
    width: 100%;
    padding: var(--spacing-md);
    background: var(--text);
    color: var(--secondary);
    border: none;
    border-radius: 4px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
  }

  .contact-btn:hover {
    background: var(--secondary);
    color: var(--text);
    border: 1px solid var(--text);
  }

  .tags {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-lg);
  }

  .tag {
    font-size: 0.8rem;
    color: var(--text-light);
    background: #f5f5f5;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: 4px;
  }

  .share-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-sm);
  }

  .share-btn {
    padding: var(--spacing-sm);
    border: 1px solid var(--border-color);
    background: transparent;
    border-radius: 4px;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.3s;
  }

  .share-btn:hover {
    background: #f5f5f5;
    border-color: var(--text);
  }

  .description-section {
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-xl);
    background: #f5f5f5;
    border-radius: 8px;
  }

  .description-section h3 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-md);
  }

  .description-section p {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.8;
  }

  .navigation-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .nav-artwork {
    padding: var(--spacing-lg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s;
  }

  .nav-artwork:hover {
    background: #f5f5f5;
    border-color: var(--text);
  }

  .nav-artwork span {
    font-size: 0.85rem;
    color: var(--text-light);
  }

  .nav-artwork p {
    font-size: 1rem;
    font-weight: 600;
    margin-top: var(--spacing-sm);
  }

  @media (max-width: 768px) {
    .work-detail {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .work-header h1 {
      font-size: 1.8rem;
    }

    .work-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .details {
      grid-template-columns: 1fr;
    }

    .navigation-section {
      grid-template-columns: 1fr;
    }

    .share-buttons {
      grid-template-columns: 1fr;
    }
  }
</style>